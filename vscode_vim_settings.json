{
  "vim.useSystemClipboard": true,
  "vim.easymotion": true,
  "vim.highlightedyank.enable": true,
  "vim.highlightedyank.color": "#a9dc7660",
  "vim.highlightedyank.duration": 200,
  "vim.timeout": 500,
  "vim.leader": "<space>",
  "vim.normalModeKeyBindingsNonRecursive": [
    {
      "before": ["<leader>", "P"],
      "commands": ["workbench.action.showCommands"]
    },
    {
      "before": ["<leader>", "p"],
      "commands": ["workbench.action.quickOpen"]
    },
    {
      "before": ["<leader>", "t"],
      "commands": ["workbench.action.gotoSymbol"]
    },

    {
      "before": ["]", "m"],
      "commands": ["editor.action.marker.nextInFiles"],
      "silent": true
    },
    {
      "before": ["[", "m"],
      "commands": ["editor.action.marker.prevInFiles"],
      "silent": true
    },
    {
      "before": ["<leader>", "b"],
      "commands": ["workbench.action.toggleSidebarVisibility"]
    },
    {
      "before": ["<leader>", "B"],
      "commands": ["workbench.action.toggleAuxiliaryBar"]
    },
    {
      "before": ["<leader>", "F"], // Search text,
      "commands": ["workbench.action.findInFiles"]
    },
    {
      "before": ["<leader>", "E"],
      "commands": ["workbench.files.action.focusOpenEditorsView"],
      "when": "workbench.explorer.openEditorsView.active"
    },
    {
      "before": ["<leader>", "e"],
      "commands": ["workbench.files.action.showActiveFileInExplorer"]
    },
    {
      "before": ["<leader>", "s"], // Search symbol
      "commands": ["workbench.action.showAllSymbols"]
    },
    {
      "before": ["<leader>", "c"],
      "commands": ["editor.action.commentLine"],
      "when": "editorTextFocus && !editorReadonly"
    },
    {
      "before": ["<leader>", "C"],
      "commands": ["editor.action.blockComment"],
      "when": "editorTextFocus && !editorReadonly"
    },
    {
      "before": ["g", "h"],
      "commands": ["editor.action.showDefinitionPreviewHover"]
    },
    {
      "before": ["g", "q"],
      "commands": ["editor.action.quickFix"]
    },
    {
      "before": ["g", "r"],
      "commands": ["editor.action.goToReferences"]
    },
    {
      "before": ["c-d"],
      "after": ["M", "c-d"]
    },
    {
      "before": ["<leader>", "r"],
      "commands": ["editor.action.rename"]
    },
    {
      "before": ["c-u"],
      "after": ["c-u", "z", "z"]
    },
    {
      "before": ["o", "o"],
      "after": ["o", "<Esc>"]
    },
    {
      "before": ["O", "O"],
      "after": ["O", "<Esc>"]
    },
    // { "before": ["J"], "after": ["5", "j"] },
    // {
    //   "before": ["K"],
    //   "after": ["5", "k"]
    // },
    // {
    //   "before": ["<leader>", "j"],
    //   "after": ["J"]
    // },

    /** Splits Navigation */
    {
      "before": ["<C-h>"],
      "after": ["<C-w>", "h"]
    },
    {
      "before": ["<C-j>"],
      "after": ["<C-w>", "j"]
    },
    {
      "before": ["<C-k>"],
      "after": ["<C-w>", "k"]
    },
    {
      "before": ["<C-l>"],
      "after": ["<C-w>", "l"]
    },

    /** Tabs Navigation */
    {
      "before": ["<leader>", "t", "t"],
      "commands": [":tabnew"]
    },
    {
      "before": ["<leader>", "t", "c"],
      "commands": [":tabclose"]
    },
    {
      "before": ["<leader>", "t", "n"],
      "commands": [":tabnext"]
    },
    {
      "before": ["<leader>", "t", "p"],
      "commands": [":tabprevious"]
    },
    {
      "before": ["<leader>", "t", "f"],
      "commands": [":tabfirst"]
    },
    {
      "before": ["<leader>", "t", "l"],
      "commands": [":tablast"]
    },
    {
      "before": ["<leader>", "t", "o"],
      "commands": [":tabo"]
    },
    {
      "before": ["<leader>", "/"],
      "commands": [":noh"]
    }
  ],
  "vim.visualModeKeyBindingsNonRecursive": [
    {
      "before": ["p"],
      "after": ["p", "g", "v", "y"]
    },
    {
      "before": ["<leader>", "c"],
      "commands": ["editor.action.commentLine"],
      "when": "editorTextFocus && !editorReadonly"
    },
    {
      "before": ["<leader>", "C"],
      "commands": ["editor.action.blockComment"],
      "when": "editorTextFocus && !editorReadonly"
    }
  ],
  "vim.visualstar": true,
  "vim.foldfix": true,
  "vim.camelCaseMotion.enable": true,
  "extensions.experimental.affinity": {
    "vscodevim.vim": 1
  }
}
